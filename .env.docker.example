# Copy to .env.docker before running: cp .env.docker.example .env.docker
# Or run: bin/docker up --build (creates .env.docker from this file automatically)

# Required — use config/master.key locally, or your production key when deploying.
RAILS_MASTER_KEY=

# Required in production — generate with: bin/rails secret
DEVISE_JWT_SECRET_KEY=

# Paystack — copy from .env for real test-mode API calls (omit to use stub mode)
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PLATFORM_FEE_PERCENT=5

# Optional overrides (defaults are set in docker-compose.yml)
# API_PORT=3001

# Ngrok (Paystack webhooks): bin/ngrok-webhook, then set TRIBETIP_API_URL to your https ngrok host.
# TRIBETIP_API_URL=https://xxxx.ngrok-free.app
# Paystack webhook URL: https://xxxx.ngrok-free.app/paystack/webhook
