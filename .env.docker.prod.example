# Production-like Docker stack — first run: bin/docker prod up --build
# bin/docker copies secrets from .env.docker or config/master.key on first use.

# Required (same as .env.docker)
RAILS_MASTER_KEY=
DEVISE_JWT_SECRET_KEY=

# Paystack — omit for stub mode; copy sk_test_... for real test API calls
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PLATFORM_FEE_PERCENT=5

# API port on host (default 3001)
# API_PORT=3001

# Puma / connection pool (see docker-compose.prod.yml for defaults)
# WEB_CONCURRENCY=2
# RAILS_MAX_THREADS=5
# DB_POOL=10
# JOB_CONCURRENCY=2

# Seed demo_creator for public profile load tests
# TRIBETIP_SEED_ENABLED=true
# TRIBETIP_SEED_PASSWORD=localdev

# Keep production rate limits during load tests to expose bottlenecks:
# RACK_ATTACK_PUBLIC_PROFILE_LIMIT=60
# RACK_ATTACK_SHARE_PROFILE_LIMIT=180
# RACK_ATTACK_WIDGET_CONFIG_LIMIT=120
