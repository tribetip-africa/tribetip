# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Bundler
/.bundle
/vendor/bundle

# Environment & secrets
/.env*
!/.env.example
/.env*.local
/config/master.key
/config/credentials/*.key
/.kamal/secrets

# Logs, temp, and runtime
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/tmp/cache/*
!/tmp/cache/
!/tmp/cache/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Storage & uploads
/storage/*
!/storage/.keep

# Databases (local SQLite artifacts, if used)
*.sqlite3
*.sqlite3-*

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editors & IDEs
.idea/
*.iml
.vscode/
*.code-workspace
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Ruby & test tooling
*.gem
*.rbc
/coverage/
/.rspec_status
/spec/examples.txt
/.byebug_history
.irb-history
.yardoc
/doc/

# Node (if frontend tooling is added later)
/node_modules/
/yarn-error.log
npm-debug.log*
.yarn-integrity

# Docker (local overrides only; keep Dockerfile in repo)
docker-compose.override.yml

# Misc local scratch
.scratch/
*.local

# Cursor (track project rules only)
.cursor/*
!.cursor/rules/
!.cursor/rules/**
