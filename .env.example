## Application
RAILS_ENV=development

## Database
# Used by config/database.yml in production.
TRIBETIP_DATABASE_PASSWORD=change-me

## Platform URLs (optional — sensible defaults per RAILS_ENV)
# Development defaults:
#   TRIBETIP_PLATFORM_URL=http://localhost:3000
#   TRIBETIP_API_URL=http://localhost:3001
# Production defaults:
#   TRIBETIP_PLATFORM_URL=https://tribetip.africa
#   TRIBETIP_API_URL=https://api.tribetip.africa
# TRIBETIP_PLATFORM_URL=http://localhost:3000
# TRIBETIP_API_URL=http://localhost:3001

## API Security
# Comma-separated browser origins allowed to call this API.
# Defaults to TRIBETIP_PLATFORM_URL (+ 127.0.0.1 alias in development).
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Comma-separated list of allowed Host headers (production).
# APP_HOSTS=api.tribetip.africa,tribetip.africa
APP_HOSTS=localhost,127.0.0.1
