## Application
RAILS_ENV=development

## Docker (API + worker + Postgres via docker-compose)
# cp .env.docker.example .env.docker   # or: bin/docker up --build (auto-creates)
# bin/docker up --build                  # http://localhost:3001
# bin/docker logs -f worker            # Solid Queue jobs (webhooks, paystack, default)
# bin/docker down

## Database
# Primary (writes + migrations). Defaults: localhost, current OS user, tribetip_development.
# DB_HOST=localhost
# DB_DATABASE=tribetip_development
# DB_USERNAME=
# DB_PASSWORD=

# Read replica (reads via Rails database_selector). Defaults to primary host/database in development.
# DB_REPLICA_HOST=localhost
# DB_REPLICA_DATABASE=tribetip_development_replica
# DB_REPLICA_USERNAME=
# DB_REPLICA_PASSWORD=

# Production primary password (REQUIRED in production).
TRIBETIP_DATABASE_PASSWORD=change-me

## Platform URLs
# Development defaults:
#   TRIBETIP_PLATFORM_URL=http://localhost:3000
#   TRIBETIP_API_URL=http://localhost:3001
# Production (set explicitly in Kamal/deploy):
#   TRIBETIP_PLATFORM_URL=https://tribetip.africa
#   TRIBETIP_API_URL=https://api.tribetip.africa

## Production security (REQUIRED when RAILS_ENV=production)
# DEVISE_JWT_SECRET_KEY=generate-with-bin-rails-secret
# APP_HOSTS=api.tribetip.africa,tribetip.africa
# CORS_ALLOWED_ORIGINS=https://tribetip.africa

## Database seeds (bin/rails db:seed)
# Development runs seeds by default. Production requires:
# TRIBETIP_SEED_ENABLED=true
# TRIBETIP_SEED_PASSWORD=your-secure-password
# Optional:
# TRIBETIP_SEED_RESET_PASSWORD=true
# TRIBETIP_SEED_CREATORS=false

## Region launch flags (signup + onboarding)
# Default in config/regions.yml: only Kenya (KE) is enabled.
# Override all flags at once:
# TRIBETIP_ENABLED_REGIONS=KE,NG
# Or toggle one market:
# TRIBETIP_REGION_NG_ENABLED=true

## Email confirmation
# true in production by default — users must confirm email before sign-in.
# false in development/test for faster local iteration.
# TRIBETIP_REQUIRE_EMAIL_CONFIRMATION=false

## Paystack (tips + creator onboarding)
# Leave blank in development to use stub checkout URLs and auto-provision accounts.
# Set sk_test_... for real Paystack test-mode API calls (checkout, customers, subaccounts).
# Copy this file to .env and set PAYSTACK_SECRET_KEY locally (never commit .env).
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PLATFORM_FEE_PERCENT=5
#
# Public checkout/onboarding waits are intentionally short so Rails workers are not held
# while background jobs or Paystack calls are slow. Frontend polling continues after 202.
# TRIBETIP_CHECKOUT_WAIT_SECONDS=10
# TRIBETIP_CUSTOMER_WAIT_SECONDS=5
# TRIBETIP_ONBOARDING_WAIT_SECONDS=10
#
# Rack::Attack limits for public payment endpoints.
# RACK_ATTACK_TIPS_LIMIT=30
# RACK_ATTACK_TIP_CHECKOUT_LIMIT=30
# RACK_ATTACK_TIP_RECONCILE_LIMIT=20
# RACK_ATTACK_TIP_REFERENCE_LIMIT=10
#
# Payout mode (how creator earnings reach their bank account):
#   auto   — Paystack auto-settles subaccount balances (default; works on Starter business)
#   manual — Creators withdraw on demand via Transfers API (requires Registered Business)
#   both   — Auto-settle subaccounts + allow manual withdraw when Transfers are enabled
# TRIBETIP_PAYOUT_MODE=auto
# TRIBETIP_MIN_WITHDRAWAL_CENTS=10000
# TRIBETIP_WITHDRAWAL_COOLDOWN_SECONDS=300
#
# Paystack business tier / transfer capability (production ops):
#   Starter accounts cannot initiate third-party Transfers — use auto mode until upgraded.
# TRIBETIP_PAYSTACK_BUSINESS_TIER=starter
# TRIBETIP_PAYSTACK_TRANSFERS_ENABLED=false
#   (optional override; auto-detected after first failed transfer and cached for 7 days)
#
# Ops checklist to enable manual withdrawals:
#   1. Upgrade Paystack account: Starter → Registered Business
#   2. Enable Transfers in Paystack dashboard (Settings → Preferences)
#   3. Set TRIBETIP_PAYSTACK_BUSINESS_TIER=registered (or TRIBETIP_PAYSTACK_TRANSFERS_ENABLED=true)
#   4. Set TRIBETIP_PAYOUT_MODE=manual (or both) and redeploy
#
# Local dev on Paystack Starter (real sk_test_ key, no Transfers API):
#   TRIBETIP_PAYOUT_MODE=manual
#   TRIBETIP_PAYSTACK_TRANSFERS_ENABLED=true
#   TRIBETIP_SIMULATE_TRANSFERS=true   # skips Paystack /transfer; completes withdrawal in-app
#
# Docker has no SMTP — mail uses :test delivery unless SMTP_ADDRESS is set.
# ACTION_MAILER_DELIVERY_METHOD=test
# Register webhook URL in Paystack dashboard:
#   https://api.tribetip.africa/paystack/webhook
#
# Local dev (ngrok):
#   1. bin/docker up --build
#   2. bin/ngrok-webhook                    # exposes http://localhost:3001
#   3. Paystack → Settings → Webhooks → add https://<ngrok-host>/paystack/webhook
#   4. bin/docker logs -f worker            # Solid Queue processes webhook jobs
#   TRIBETIP_ALLOW_NGROK_HOSTS=true is set in docker-compose.yml for ngrok Host headers.

# Solid Cache is used in production (see config/cache.yml).

## API Security (development)
APP_HOSTS=localhost,127.0.0.1
